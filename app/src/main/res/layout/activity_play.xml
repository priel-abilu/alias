<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FA"
    tools:context=".Play">

    <!-- Timer -->
    <TextView
        android:id="@+id/timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:30"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FF5252"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"/>

    <!-- Group Name -->
    <TextView
        android:id="@+id/NameGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Group A"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#444"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp"/>

    <!-- Word Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardWord"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        android:layout_margin="24dp"
        app:layout_constraintTop_toBottomOf="@id/NameGroup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/Word"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WORD"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:padding="32dp"
            android:textColor="#222"/>
    </androidx.cardview.widget.CardView>

    <!-- Forbidden Words -->
    <TextView
        android:id="@+id/forbidden"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Forbidden: example1, example2, example3"
        android:textSize="16sp"
        android:textColor="#666"
        android:gravity="center"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/cardWord"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_margin="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="60dp"
            android:text="Skip"
            android:textColor="@android:color/white"
            android:backgroundTint="#FF9800"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="60dp"
            android:text="Next"
            android:textColor="@android:color/white"
            android:backgroundTint="#4CAF50"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>